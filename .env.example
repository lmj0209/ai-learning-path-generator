# ========================================
# AI/LLM API Keys (REQUIRED)
# ========================================

# OpenAI API Key - Required for AI model interactions
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key - Alternative LLM provider
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ========================================
# Embedding API Configuration
# ========================================

# Embedding API Key - defaults to OPENAI_API_KEY if not set
# For Gitee AI (模力方舟): use your Gitee AI access token
EMBEDDING_API_KEY=your_gitee_ai_token_here

# Embedding API Base URL - supports any OpenAI-compatible endpoint
# Gitee AI: https://ai.gitee.com/v1
# OpenAI: https://api.openai.com/v1 (default if not set)
EMBEDDING_BASE_URL=https://ai.gitee.com/v1

# Embedding Model Name
# Gitee AI free models: BAAI/bge-m3 (recommended), Qwen3-Embedding-8B, jina-embeddings-v4
# OpenAI: text-embedding-3-small, text-embedding-ada-002
EMBEDDING_MODEL=BAAI/bge-m3

# ========================================
# Model Configuration
# ========================================

# Optional: Configure model settings
DEFAULT_PROVIDER=deepseek
DEFAULT_MODEL=deepseek-chat
# MAX_TOKENS=1000
# TEMPERATURE=0.7

# ========================================
# Flask Configuration
# ========================================

# Development environment settings
FLASK_APP=run.py
FLASK_ENV=development
FLASK_SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Port (Render will set this automatically)
PORT=5000

# ========================================
# Database Configuration
# ========================================

# PostgreSQL Database URL (Render will provide this)
# For local development, leave empty to use SQLite
DATABASE_URL=

# ========================================
# Redis Configuration
# ========================================

# Redis URL (Render will provide this when you add Redis add-on)
# For local development with Docker: redis://localhost:6379
REDIS_URL=

# Alternative Redis configuration (for local development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# Google OAuth Configuration
# ========================================

# Google OAuth credentials (obtain from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# ========================================
# Observability & Monitoring (OPTIONAL)
# ========================================

# LangSmith Configuration (for LLM tracing and debugging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ai-learning-path-generator

# Weights & Biases Configuration (for metrics and experiment tracking)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=ai-learning-path-generator
WANDB_ENTITY=your_wandb_username_or_team

# ========================================
# Other Configuration
# ========================================

# Enable mock backend data for UI testing (set to True locally only)
ENABLE_MOCK_DATA=False

# Vector DB path (local ChromaDB)
VECTOR_DB_PATH=./vector_db

# Render environment detection (automatically set by Render)
# RENDER=true
